NEXT_PUBLIC_SITE_URL=https://botmate.mx
NEXT_PUBLIC_WHATSAPP=525531491986
NEXT_PUBLIC_EMAIL=contacto@botmate.mx

# Vitala — Coach IA (opcional). Sin esta llave, el coach degrada a respuestas seguras por reglas.
# Consigue tu llave en https://console.anthropic.com  → nunca la subas al repo.
ANTHROPIC_API_KEY=
# Modelo a usar (por costo: haiku; por calidad: claude-sonnet-4-6)
VITALA_AI_MODEL=claude-haiku-4-5-20251001

# Vitala — Cuentas personales con Supabase (login con Google). Sin esto, la app
# funciona en "modo local" (datos en el dispositivo). Llaves públicas, ver docs/VITALA-SUPABASE.md
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vitala — Pago "1 peso" de por vida (Stripe). Sin llave, el flujo corre en modo demo.
# Crea tu cuenta en stripe.com y usa la Secret key. Ajusta precio/moneda a tu país.
STRIPE_SECRET_KEY=
VITALA_PRICE_CENTS=100
VITALA_CURRENCY=mxn
