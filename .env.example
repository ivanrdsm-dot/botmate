NEXT_PUBLIC_SITE_URL=https://botmate.mx
NEXT_PUBLIC_WHATSAPP=525531491986
NEXT_PUBLIC_EMAIL=contacto@botmate.mx

# Vitala — Coach IA (opcional). Sin esta llave, el coach degrada a respuestas seguras por reglas.
# Consigue tu llave en https://console.anthropic.com  → nunca la subas al repo.
ANTHROPIC_API_KEY=
# Modelo a usar. Costo (entrada/salida por 1M tokens):
#   claude-haiku-4-5  -> $1/$5   (recomendado para escala "1 peso")
#   claude-sonnet-4-6 -> $3/$15  (balance calidad/costo)
#   claude-opus-4-8   -> $5/$25  (máxima calidad, premium)
VITALA_AI_MODEL=claude-haiku-4-5

# Vitala — Cuentas personales con Supabase (login con Google). Sin esto, la app
# funciona en "modo local" (datos en el dispositivo). Llaves públicas, ver docs/VITALA-SUPABASE.md
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRETA — solo servidor. Necesaria para borrar la cuenta (auth.admin.deleteUser).
# Supabase → Project Settings → API → service_role. NUNCA la pongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Dominio propio de Vitala (marca aparte). Cuando lo configures, ese dominio
# servirá la app de Vitala en su raíz. Déjalo vacío para no activarlo.
# Ej: VITALA_HOST=vitala.health
VITALA_HOST=

# Vitala — Pago "1 peso" de por vida (Stripe). Sin llave, el flujo corre en modo demo.
# Crea tu cuenta en stripe.com y usa la Secret key. Ajusta precio/moneda a tu país.
STRIPE_SECRET_KEY=
VITALA_PRICE_CENTS=100
VITALA_CURRENCY=mxn
